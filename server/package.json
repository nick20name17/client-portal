{
  "name": "app",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build --compile --minify --sourcemap ./src/index.ts --outfile ./dist/elysia-server",
    "start": "./dist/elysia-server",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "email": "email dev --dir src/emails"
  },
  "dependencies": {
    "@better-auth/core": "1.5.6",
    "@better-auth/drizzle-adapter": "latest",
    "@elysiajs/cors": "latest",
    "@elysiajs/openapi": "latest",
    "@react-email/components": "^1.0.11",
    "@sinclair/typebox": "latest",
    "better-auth": "latest",
    "drizzle-orm": "latest",
    "drizzle-typebox": "^0.3.3",
    "elysia": "latest",
    "pg": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/pg": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-types": "latest",
    "drizzle-kit": "latest",
    "react-email": "^5.2.10"
  },
  "main": "src/index.ts",
  "module": "src/index.ts"
}
